# FastAPI — use your deployed API URL in production (not localhost).
# Local example: http://127.0.0.1:8000
NEXT_PUBLIC_API_URL=

# Supabase — client must use NEXT_PUBLIC_* (not the secret key).
NEXT_PUBLIC_SUPABASE_URL=
# Same as URL; supported if your dashboard uses “project URL” naming:
# NEXT_PUBLIC_SUPABASE_PROJECT_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Legacy name (same value as publishable):
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secret / service role — never NEXT_PUBLIC_*:
# SUPABASE_SECRET_KEY=

# Optional non-public fallbacks (build/server):
# SUPABASE_PROJECT_URL=
# SUPABASE_PUBLISHABLE_KEY=

# AI keys (server)
# ANTHROPIC_API_KEY=
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=

# NEXT_PUBLIC_ONBOARDING_DONE_KEY=
# NEXT_PUBLIC_PROFILE_KEY=
