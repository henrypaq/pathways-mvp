# FastAPI — use your deployed API URL in production (not localhost).
# Local example: http://127.0.0.1:8000
NEXT_PUBLIC_API_URL=

# Supabase — client must use NEXT_PUBLIC_* (not the secret key).
NEXT_PUBLIC_SUPABASE_URL=
# Same as URL; supported if your dashboard uses “project URL” naming:
# NEXT_PUBLIC_SUPABASE_PROJECT_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Legacy name (same value as publishable):
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secret / service role — never NEXT_PUBLIC_*:
# SUPABASE_SECRET_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Python API + pipeline: vector reads default to Supabase pgvector.
# PATHWAYS_VECTOR_BACKEND=supabase
# Legacy local Chroma reads only:
# PATHWAYS_VECTOR_BACKEND=chroma

# Optional: dual-write scraped chunks to local Chroma during ingest (default off).
# CHROMA_ENABLED=1

# Data pipeline / RAG: Postgres connection for pgvector (Dashboard → Database → URI).
# Prefer direct/session connection for bulk ingest; pooler often works too.
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Optional alias:
# DATABASE_URL=

# Optional non-public fallbacks (build/server):
# SUPABASE_PROJECT_URL=
# SUPABASE_PUBLISHABLE_KEY=

# AI keys (server)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=   # embeddings: text-embedding-3-small (ingest + vector search)
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID_EN=   # English voice ID
# ELEVENLABS_VOICE_ID_FR=   # French voice ID
# ELEVENLABS_MODEL_ID=      # optional, default: eleven_multilingual_v2

# NEXT_PUBLIC_ONBOARDING_DONE_KEY=
# NEXT_PUBLIC_PROFILE_KEY=
