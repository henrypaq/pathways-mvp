# FastAPI — use your deployed API URL in production (not localhost).
# Local example: http://127.0.0.1:8000
NEXT_PUBLIC_API_URL=

# Supabase — browser OAuth requires NEXT_PUBLIC_* (inlined at build time)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase dashboard “publishable” key = same as anon; still needs NEXT_PUBLIC_ for client:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server / CI only (not available in browser bundle):
# SUPABASE_PROJECT_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_PUBLISHABLE_KEY=

# AI keys (server)
# ANTHROPIC_API_KEY=
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=

# NEXT_PUBLIC_ONBOARDING_DONE_KEY=
# NEXT_PUBLIC_PROFILE_KEY=
